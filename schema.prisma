generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DB_FILE_NAME")
}

model User {
  // Adaptive AI platform columns (do not change)
  id     String  @id
  name   String?
  image  String?
  handle String?

  // Additional columns
  applications       GigApplication[]
  profile            UserProfile?
  championedProjects RestorationProject[]
  laborPledges       LaborPledge[]
}

model HousingListing {
  id            String   @id @default(cuid())
  type          String   // "rent" | "sale"
  propertyType  String   // "apartment" | "house" | "room" | "commercial"
  price         Float
  address       String
  neighborhood  String   @default("")
  bedrooms      Int      @default(0)
  bathrooms     Float    @default(1)
  sqft          Int      @default(0)
  description   String
  utilitiesIncl Boolean  @default(false)
  petFriendly   Boolean  @default(false)
  parking       Boolean  @default(false)
  contactName   String
  contactEmail  String
  createdAt     DateTime @default(now())
}

model RestorationProject {
  id            String             @id @default(cuid())
  address       String
  city          String
  status        String             // "foreclosed" | "abandoned" | "auction" | "tax_lien"
  proposedUse   String             // "housing" | "community" | "mixed"
  estimatedCost Float
  fundingGoal   Float
  amountRaised  Float              @default(0)
  backerCount   Int                @default(0)
  championId    String
  champion      User               @relation(fields: [championId], references: [id])
  description   String
  updates       RestorationUpdate[]
  laborPledges  LaborPledge[]
  createdAt     DateTime           @default(now())
}

model RestorationUpdate {
  id        String             @id @default(cuid())
  projectId String
  project   RestorationProject @relation(fields: [projectId], references: [id])
  content   String
  createdAt DateTime           @default(now())
}

model LaborPledge {
  id        String             @id @default(cuid())
  projectId String
  project   RestorationProject @relation(fields: [projectId], references: [id])
  userId    String
  user      User               @relation(fields: [userId], references: [id])
  skill     String
  hours     Int
  createdAt DateTime           @default(now())
}

model GigListing {
  id           String           @id @default(cuid())
  title        String
  category     String
  payRate      String
  location     String
  description  String
  posterName   String
  posterEmail  String
  isCareer     Boolean          @default(false)
  createdAt    DateTime         @default(now())
  applications GigApplication[]
}

model GigApplication {
  id        String     @id @default(cuid())
  gigId     String
  gig       GigListing @relation(fields: [gigId], references: [id])
  userId    String
  user      User       @relation(fields: [userId], references: [id])
  message   String
  createdAt DateTime   @default(now())
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  bio         String   @default("")
  skills      String   @default("")
  workHistory String   @default("")
  phone       String   @default("")
  location    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
